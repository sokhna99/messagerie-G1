<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.controllers.LoginController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1F4E79; -fx-padding: 40;">

    <Label text="💬 Messagerie G1"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <VBox spacing="10" maxWidth="350"
          style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">

        <Label text="Connexion"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F4E79;"/>

        <Label text="Nom d'utilisateur" style="-fx-font-size: 13px;"/>
        <TextField fx:id="usernameField" promptText="Entrez votre username"/>

        <Label text="Mot de passe" style="-fx-font-size: 13px;"/>
        <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" wrapText="true"/>

        <Button fx:id="loginButton" text="Se connecter"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-cursor: hand;"/>

        <Separator/>

        <Button text="Créer un compte"
                onAction="#goToRegister"
                maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #2E75B6; -fx-font-size: 13px; -fx-cursor: hand;"/>
    </VBox>
</VBox>
